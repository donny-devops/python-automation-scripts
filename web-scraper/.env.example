SCRAPER_HEADLESS=true
SCRAPER_DELAY_MIN=1.0
SCRAPER_DELAY_MAX=3.0
SCRAPER_MAX_RETRIES=3
SCRAPER_CONCURRENCY=5
SCRAPER_OUTPUT_DIR=./output
SCRAPER_USER_AGENT=random      # random | custom | default
PROXY_URL=                     # optional: http://user:pass@host:port

# Storage backends (pick one or both)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=scraper
POSTGRES_URL=postgresql://user:pass@localhost:5432/scraper
